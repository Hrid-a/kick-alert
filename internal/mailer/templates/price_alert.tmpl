{{define "subject"}}{{if eq .alertType "PRICE_DROP"}}Price Drop on {{.productName}}{{else if eq .alertType "RESTOCK"}}{{.productName}} is Back in Stock{{else}}Price Update on {{.productName}}{{end}}{{end}}

{{define "plainBody"}}
Hi {{.name}},

{{if eq .alertType "PRICE_DROP"}}
Good news! The price of {{.productName}} just dropped.

Old price: {{.currency}} {{.oldPrice}}
New price: {{.currency}} {{.newPrice}}
{{else if eq .alertType "RESTOCK"}}
{{.productName}} is back in stock!
{{else}}
The price of {{.productName}} has changed.

Old price: {{.currency}} {{.oldPrice}}
New price: {{.currency}} {{.newPrice}}
{{end}}

View product: {{.productURL}}

Thanks,
The kick-alert Team
{{end}}

{{define "htmlBody"}}
<!doctype html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: #f4f7f6;
            margin: 0;
            padding: 0;
        }
        .wrapper {
            max-width: 560px;
            margin: 40px auto;
            background: #ffffff;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        }
        .header {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            padding: 40px 48px;
            text-align: center;
        }
        .header h1 {
            color: #ffffff;
            margin: 0;
            font-size: 28px;
            font-weight: 700;
            letter-spacing: -0.5px;
        }
        .header p {
            color: #7ec8e3;
            margin: 6px 0 0;
            font-size: 14px;
            letter-spacing: 1px;
            text-transform: uppercase;
        }
        .body {
            padding: 40px 48px;
            color: #374151;
            font-size: 15px;
            line-height: 1.7;
        }
        .body h2 {
            margin: 0 0 8px;
            font-size: 20px;
            color: #111827;
        }
        .price-box {
            background: #f0fdf4;
            border: 1px solid #bbf7d0;
            border-radius: 10px;
            padding: 20px 24px;
            margin: 24px 0;
            display: flex;
            gap: 24px;
        }
        .price-item {
            flex: 1;
        }
        .price-label {
            font-size: 12px;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 4px;
        }
        .price-old {
            font-size: 18px;
            color: #9ca3af;
            text-decoration: line-through;
        }
        .price-new {
            font-size: 24px;
            font-weight: 700;
            color: #16a34a;
        }
        .restock-badge {
            display: inline-block;
            background: #dcfce7;
            border: 1px solid #86efac;
            color: #15803d;
            border-radius: 6px;
            padding: 6px 16px;
            font-size: 14px;
            font-weight: 600;
            margin: 16px 0;
        }
        .cta-wrapper {
            text-align: center;
            margin: 32px 0;
        }
        .cta-button {
            display: inline-block;
            background: linear-gradient(135deg, #0f3460, #1a1a2e);
            color: #ffffff !important;
            text-decoration: none;
            padding: 14px 36px;
            border-radius: 8px;
            font-size: 15px;
            font-weight: 600;
            letter-spacing: 0.3px;
        }
        .footer {
            background: #f9fafb;
            border-top: 1px solid #e5e7eb;
            padding: 24px 48px;
            text-align: center;
            font-size: 12px;
            color: #9ca3af;
            line-height: 1.6;
        }
        .footer strong {
            color: #6b7280;
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="header">
            <h1>✦ kick-alert</h1>
            <p>
                {{if eq .alertType "PRICE_DROP"}}Price Drop Alert{{else if eq .alertType "RESTOCK"}}Restock Alert{{else}}Price Update{{end}}
            </p>
        </div>

        <div class="body">
            <h2>Hi {{.name}},</h2>

            {{if eq .alertType "PRICE_DROP"}}
            <p>Good news — <strong>{{.productName}}</strong> just dropped in price!</p>
            <div class="price-box">
                <div class="price-item">
                    <div class="price-label">Was</div>
                    <div class="price-old">{{.currency}} {{.oldPrice}}</div>
                </div>
                <div class="price-item">
                    <div class="price-label">Now</div>
                    <div class="price-new">{{.currency}} {{.newPrice}}</div>
                </div>
            </div>
            {{else if eq .alertType "RESTOCK"}}
            <p><strong>{{.productName}}</strong> is back in stock!</p>
            <div style="margin: 24px 0;">
                <span class="restock-badge">Back in Stock</span>
            </div>
            {{else}}
            <p>The price of <strong>{{.productName}}</strong> has changed.</p>
            <div class="price-box">
                <div class="price-item">
                    <div class="price-label">Was</div>
                    <div class="price-old">{{.currency}} {{.oldPrice}}</div>
                </div>
                <div class="price-item">
                    <div class="price-label">Now</div>
                    <div class="price-new">{{.currency}} {{.newPrice}}</div>
                </div>
            </div>
            {{end}}

            <div class="cta-wrapper">
                <a href="{{.productURL}}" class="cta-button">View Product →</a>
            </div>
        </div>

        <div class="footer">
            <strong>The kick-alert Team</strong><br />
            You received this because you are watching this product.<br />
            Manage your alerts in your watchlist settings.
        </div>
    </div>
</body>
</html>
{{end}}
